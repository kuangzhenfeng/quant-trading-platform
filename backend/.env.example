# === 认证配置 ===
AUTH_ENABLED=false
AUTH_DEFAULT_USERNAME=admin
AUTH_DEFAULT_PASSWORD=admin123
AUTH_JWT_SECRET=your-secret-key-change-in-production
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_DAYS=7

# === 数据库配置 ===
# 开发环境使用SQLite（无需安装PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./quant_trading.db
# 生产环境使用PostgreSQL（需要先启动PostgreSQL服务）
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/quant_trading

# 交易模式 (live/paper/mock)
TRADING_MODE=mock

# === OKX 配置 ===
# Live 模式（实盘）
OKX_LIVE_API_KEY=
OKX_LIVE_SECRET_KEY=
OKX_LIVE_PASSPHRASE=

# Paper 模式（模拟盘）
OKX_PAPER_API_KEY=
OKX_PAPER_SECRET_KEY=
OKX_PAPER_PASSPHRASE=

# === Moomoo 配置 ===
# Live 模式（实盘）
# MOOMOO_LIVE_HOST=127.0.0.1
# MOOMOO_LIVE_PORT=11111

# Paper 模式（模拟盘）
# MOOMOO_PAPER_HOST=127.0.0.1
# MOOMOO_PAPER_PORT=11111

# === 国金证券配置 ===
# Live 模式（实盘）
GUOJIN_LIVE_ACCOUNT_ID=
GUOJIN_LIVE_PASSWORD=
